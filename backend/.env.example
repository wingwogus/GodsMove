# 로컬 실행용 환경변수 템플릿.
# 실제 값은 `cp .env.example .env` 후 .env 에 채운다. .env 는 gitignore 대상이다.

# 공공데이터포털(data.go.kr) 기상청 API 인증키.
# 반드시 "Encoding" 키를 사용한다. Decoding 키(+, /, = 포함)를 넣으면 401 이 뜬다.
# 아래 4개 서비스 각각에 대해 활용신청이 되어 있어야 한다:
#   - 단기예보 조회서비스 (VilageFcstInfoService_2.0)
#   - 종관기상관측(ASOS) 일자료 (AsosDalyInfoService)
#   - 생활기상지수 (LivingWthrIdxServiceV5)
#   - 중기예보 조회서비스 (MidFcstInfoService)
KMA_SERVICE_KEY=

# 공공데이터포털은 2초를 자주 넘긴다. 로컬 검증 시 넉넉하게 둔다.
KMA_CONNECT_TIMEOUT_MILLIS=5000
KMA_READ_TIMEOUT_MILLIS=10000

# 기본값은 create(재기동마다 스키마 재생성). 반복 테스트 중 데이터를 유지하려면
# update로 바꾼다. Flyway가 없어 update는 Hibernate가 엔티티 diff로 스키마를
# 알아서 ALTER하니, 예상 못한 스키마 변경이 보이면 지우고 create로 한 번 재생성한다.
SPRING_JPA_HIBERNATE_DDL_AUTO=create

# OpenAI Realtime(음성 기록) 세션 발급용 API 키. 비우면 세션 발급이 전부 VOICE_003으로
# 실패한다. 주의: gradlew bootRun은 이 파일을 자동 로딩하지 않으므로 실행 전 export 필요.
OPENAI_API_KEY=
